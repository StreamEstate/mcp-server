{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.fullstck/stream-estate",
  "description": "MCP server for the Stream.estate French real estate API",
  "repository": {
    "url": "https://github.com/StreamEstate/mcp-server",
    "source": "github"
  },
  "version": "1.0.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-stream-estate",
      "version": "1.0.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "STREAM_ESTATE_API_KEY",
          "description": "Your Stream.estate API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
